mixin formConsultation(borderless, type)
    //- регистрация
    //- +regLibrary('lib-name/lib.css', 'lib-name/lib.js')
    //- +regComponent('component-name', true, true)
    +regComponent('input', true, true)
    +regComponent('textarea', true, true)
    +regComponent('checkbox', true)
    +regComponent('radio', true)
    //form-consultation
    .form-consultation&attributes(attributes)
        .form-consultation__body
            if type === 'contacts'
              p.form-consultation__title Меня интересует:
            form(data-form="consultation").form-consultation__form
                fieldset.form-consultation__form_fieldset
                    if type === 'contacts'
                        .form-consultation__types
                            +radio("type", "HR порталы")
                            +radio("type", "ERP системы")
                            +radio("type", "CRM системы")
                            +radio("type", "Корпоративные порталы")
                            +radio("type", "Документооборот")
                            +radio("type", "Личные кабинеты")
                            +radio("type", "E-commerce")
                    .form-consultation__form_top
                        if type === 'contacts'
                            .form-consultation__form_field
                                +input('company', 'Компания', '')(class=`${borderless ? 'borderless' : ''}`)
                            .form-consultation__form_field
                                +input('name', 'Ваше имя*', 'Некорректное имя')(class=`${borderless ? 'borderless' : ''}`)
                        else
                            .form-consultation__form_field
                                +input('name', 'Ваше имя*', 'Некорректное имя')(class=`${borderless ? 'borderless' : ''}`)
                            .form-consultation__form_field
                                +input('company', 'Компания', '')(class=`${borderless ? 'borderless' : ''}`)
                        .form-consultation__form_field
                            +input('phone', 'Телефон*', 'Некорректный номер', 'input--phone', 'numeric')(class=`${borderless ? 'borderless' : ''}`)
                        .form-consultation__form_field
                            +input('email', 'E-mail*', 'Некорректный email', '', 'email')(class=`${borderless ? 'borderless' : ''}`)
                        .form-consultation__form_field
                            +textarea('description', 'Расскажите о задаче')(class=`${borderless ? 'borderless' : ''}`)
                    .form-consultation__form_middle
                        .form-consultation__deadlines
                            p.form-consultation__deadlines_title Сроки
                            .form-consultation__deadlines_values
                                +radio("deadline", "1-3 месяца")
                                +radio("deadline", "3-6 месяцев")
                                +radio("deadline", "6-12 месяцев")
                                +radio("deadline", "Более 12 месяцев")
                    .form-consultation__form_footer
                        button.btn.primary.lg Оставить заявку
                        label.form-pin
                            input(type="file", name="file")
                            span.form-pin__icon
                                +svg("pin")
                            span.form-pin__label Прикрепить файл
                .form-note
                    label.checkbox
                        input.checkbox__input(type="checkbox", name="policy", value="agree", required)
                        if type === 'contacts'
                            span.checkbox__label
                                | Даю
                                |
                                a(href="#", target="_blank") согласие
                                |
                                | на обработку моих
                                |
                                a(href="#", target="_blank") персональных данных
                        else
                            span.checkbox__label
                                | Даю
                                |
                                a(href="#", target="_blank") согласие
                                |
                                | на обработку моих
                                |
                                a(href="#", target="_blank") персональных данных
                                |
                                | в соответствии
                                |
                                a(href="#", target="_blank") с&nbsp;политикой конфиденциальности
